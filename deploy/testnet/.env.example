# Pin to git SHA tag (never use 'latest' in production)
# Get current SHA: git rev-parse --short=7 HEAD
QPB_IMAGE=ghcr.io/scottdhughes/qpb-node:81e1615

# RPC authentication (required - generate random password)
# openssl rand -base64 24 | tr -d '/+='
RPC_USER=qpb
RPC_PASS=CHANGE_ME_RANDOM_PASSWORD
